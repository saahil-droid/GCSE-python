import numpy as np
import tensorflow as tf
from sklearn.model_selection import train_test_split
import pickle


#load the preprocessed data

with open('flux_dataFULL.pkl', 'rb') as f:
    flux_data = pickle.load(f)
    
with open('labelsFULL.pkl', 'rb') as f:
    labels = pickle.load(f)

print("flux_data and labels loaded successfully.")

#normalize data - so all light curves are on the same scale, which helps the model learn better.

max_length = 5000
standardized_data = []

for flux in flux_data:
    flux = np.asarray(flux).flatten()
    flux = flux[~np.isnan(flux)]
    
    # Normalize BEFORE padding/truncating
    if len(flux) > 0:
        flux = (flux - np.mean(flux)) / np.std(flux)
    
    if len(flux) >= max_length:
        standardized = flux[:max_length]
    else:
        standardized = np.pad(flux, (0, max_length - len(flux)), constant_values=0)
    
    standardized_data.append(standardized)

X = np.array(standardized_data)
Y = np.array(labels)


print(f"X shape: {X.shape}, Y shape: {Y.shape}")

# Split into training (80%) and testing (20%)
X_train, X_test, y_train, y_test = train_test_split(X, Y, test_size=0.2, random_state=42)
# Reshape for CNN - add feature dimension
X_train = X_train.reshape(X_train.shape[0], 5000, 1)
X_test = X_test.reshape(X_test.shape[0], 5000, 1)

print(f"Reshaped training: {X_train.shape}")  # Should be (80, 5000, 1)
print(f"Reshaped test: {X_test.shape}")      # Should be (20, 5000, 1)

callbacks = [
    tf.keras.callbacks.EarlyStopping(
        monitor='val_loss', #stop training if validation loss doesn't improve for 5 consecutive epochs
        patience=5, #number of epochs to wait before stopping after last improvement
        restore_best_weights=True #restore model weights from the epoch with the best validation loss
    )
]
#train the CNN model now
#i swapped our a complex model with a simpler one. to reduce overfitting


model = tf.keras.Sequential([
    tf.keras.layers.Conv1D(32, 5, activation='relu', input_shape=(5000, 1)),
    tf.keras.layers.MaxPooling1D(2),
    tf.keras.layers.Conv1D(64, 5, activation='relu'),
    tf.keras.layers.MaxPooling1D(2),
    tf.keras.layers.Flatten(),
    tf.keras.layers.Dense(64, activation='relu', 
                      kernel_regularizer=tf.keras.regularizers.l2(0.01)),
    tf.keras.layers.Dropout(0.7),
    tf.keras.layers.Dense(1, activation='sigmoid')
])


#model = tf.keras.Sequential([# First conv layer: learns basic patterns in the light curve
 #   tf.keras.layers.Conv1D(32, kernel_size=5, activation='relu', input_shape=(5000, 1)),# Pool: reduces data size, keeps important features
  #  tf.keras.layers.MaxPooling1D(pool_size=2),# Second conv layer: learns more complex patterns
   # tf.keras.layers.Conv1D(64, kernel_size=5, activation='relu'),# Pool again
    #tf.keras.layers.MaxPooling1D(pool_size=2),# Flatten: convert to 1D for dense layers
    #tf.keras.layers.Flatten(),# Dense layer: combines features for decision making
    #tf.keras.layers.Dense(128, activation='relu'),# Output: single neuron for binary classification (planet or not)
    #tf.keras.layers.Dense(1, activation='sigmoid') #binary classification, sigmoid activation gives outpur between 0 and 1
#])

model.compile(optimizer='adam',
              loss='binary_crossentropy', #binary classification problem
              metrics=['accuracy'])

model.fit(X_train, y_train, epochs=50, batch_size=8, validation_split=0.2, callbacks=callbacks)

#model.fit(X_train, y_train, epochs=20, batch_size=8)
test_loss, test_acc = model.evaluate(X_test, y_test, verbose=2)
print(f'\nTest accuracy: {test_acc}')


import matplotlib.pyplot as plt

# Make predictions on test set
predictions = model.predict(X_test)

# Test on first 20 examples
num_samples = 20
plt.figure(figsize=(15, 10))

correct = 0
incorrect = 0

for i in range(num_samples):
    pred_prob = predictions[i][0]
    pred_label = 1 if pred_prob > 0.5 else 0
    true_label = y_test[i]
    
    # Count successes
    if pred_label == true_label:
        correct += 1
    else:
        incorrect += 1
    
    # Plot the light curve
    plt.subplot(4, 5, i+1)
    plt.plot(X_test[i].flatten())
    plt.title(f"True: {true_label}, Pred: {pred_label}\nConf: {pred_prob:.2f}", 
              fontsize=8, 
              color='green' if pred_label == true_label else 'red')
    plt.xticks([])
    plt.yticks([])

plt.tight_layout()
plt.savefig('predictions_grid.png')
plt.show()

# Print summary table
print("\n" + "="*50)
print("RESULTS SUMMARY")
print("="*50)
print(f"Total tested: {num_samples}")
print(f"Correct: {correct} ({correct/num_samples*100:.1f}%)")
print(f"Incorrect: {incorrect} ({incorrect/num_samples*100:.1f}%)")
print("="*50)



# Save the trained model
model.save('exoplanet_model.keras')
print("Model saved to exoplanet_model.keras")
