
import numpy as np
import tensorflow as tf
from sklearn.model_selection import train_test_split
import pickle


#load the preprocessed data

with open('flux_dataFULL.pkl', 'rb') as f:
    flux_data = pickle.load(f)
    
with open('labelsFULL.pkl', 'rb') as f:
    labels = pickle.load(f)  

print("flux_data and labels loaded successfully.")

#normalize data - so all light curves are on the same scale, which helps the model learn better.

max_length = 5000
standardized_data = []

for flux in flux_data:
    flux = np.asarray(flux).flatten()
    flux = flux[~np.isnan(flux)]
    
    # Normalize BEFORE padding/truncating
    if len(flux) > 0:
        flux = (flux - np.mean(flux)) / np.std(flux)
    
    if len(flux) >= max_length:
        standardized = flux[:max_length]
    else:
        standardized = np.pad(flux, (0, max_length - len(flux)), constant_values=0)
    
    standardized_data.append(standardized)

X = np.array(standardized_data)
Y = np.array(labels)


print(f"X shape: {X.shape}, Y shape: {Y.shape}")

# Split into training (80%) and testing (20%)
X_train, X_test, y_train, y_test = train_test_split(X, Y, test_size=0.2, random_state=42)
# Reshape for CNN - add feature dimension
X_train = X_train.reshape(X_train.shape[0], 5000, 1)
X_test = X_test.reshape(X_test.shape[0], 5000, 1)

print(f"Reshaped training: {X_train.shape}")  # Should be (80, 5000, 1)
print(f"Reshaped test: {X_test.shape}")      # Should be (20, 5000, 1)

callbacks = [
    tf.keras.callbacks.EarlyStopping(
        monitor='val_loss', #stop training if validation loss doesn't improve for 5 consecutive epochs
        patience=5, #number of epochs to wait before stopping after last improvement
        restore_best_weights=True #restore model weights from the epoch with the best validation loss
    )
]


# Train 5 models
models = []
for i in range(5):
    print(f"\n=== Training Model {i+1}/5 ===")
    
    model = tf.keras.Sequential([
        tf.keras.layers.Conv1D(32, 5, activation='relu', input_shape=(5000, 1)),
        tf.keras.layers.MaxPooling1D(2),
        tf.keras.layers.Conv1D(64, 5, activation='relu'),
        tf.keras.layers.MaxPooling1D(2),
        tf.keras.layers.Flatten(),
        tf.keras.layers.Dense(64, activation='relu', 
                              kernel_regularizer=tf.keras.regularizers.l2(0.01)),
        tf.keras.layers.Dropout(0.7),
        tf.keras.layers.Dense(1, activation='sigmoid')
    ])
    
    model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
    
    model.fit(X_train, y_train, epochs=50, batch_size=16,
              validation_split=0.2, callbacks=callbacks, verbose=1)
    
    models.append(model)
    print(f"Model {i+1} completed")

# Make ensemble predictions
predictions = []
for model in models:
    pred = model.predict(X_test, verbose=0)
    predictions.append(pred)

# Average predictions
ensemble_pred = np.mean(predictions, axis=0)
ensemble_labels = (ensemble_pred > 0.5).astype(int)

# Evaluate
accuracy = np.mean(ensemble_labels.flatten() == y_test)
print(f"\nEnsemble Test Accuracy: {accuracy}")
